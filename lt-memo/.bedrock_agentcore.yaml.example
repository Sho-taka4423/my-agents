default_agent: lt_memo
agents:
  lt_memo:
    name: lt_memo
    language: python
    node_version: '20'
    entrypoint: /path/to/my-agents/lt-memo/src/agentcore_app.py
    deployment_type: container
    runtime_type: null
    platform: linux/arm64
    container_runtime: docker
    source_path: /path/to/my-agents/lt-memo
    aws:
      execution_role: arn:aws:iam::YOUR_ACCOUNT_ID:role/AmazonBedrockAgentCoreSDKRuntime-ap-northeast-1-XXXXXXXXXX
      execution_role_auto_create: false
      account: YOUR_ACCOUNT_ID
      region: ap-northeast-1
      ecr_repository: YOUR_ACCOUNT_ID.dkr.ecr.ap-northeast-1.amazonaws.com/lt-memo
      ecr_auto_create: false
      s3_path: null
      s3_auto_create: false
      network_configuration:
        network_mode: PUBLIC
        network_mode_config: null
      protocol_configuration:
        server_protocol: HTTP
      observability:
        enabled: true
      lifecycle_configuration:
        idle_runtime_session_timeout: null
        max_lifetime: null
    bedrock_agentcore:
      agent_id: null           # agentcore deploy 後に自動設定される
      agent_arn: null
      agent_session_id: null
    codebuild:
      project_name: bedrock-agentcore-lt_memo-builder
      execution_role: arn:aws:iam::YOUR_ACCOUNT_ID:role/AmazonBedrockAgentCoreSDKCodeBuild-ap-northeast-1-XXXXXXXXXX
      source_bucket: bedrock-agentcore-codebuild-sources-YOUR_ACCOUNT_ID-ap-northeast-1
    memory:
      mode: STM_ONLY
      memory_id: null          # agentcore deploy 後に自動設定される
      memory_arn: null
      memory_name: lt_memo_mem
      event_expiry_days: 30
      first_invoke_memory_check_done: false
      was_created_by_toolkit: false
    identity:
      credential_providers: []
      workload: null
    aws_jwt:
      enabled: false
      audiences: []
      signing_algorithm: ES384
      issuer_url: null
      duration_seconds: 300
    authorizer_configuration: null
    request_header_configuration: null
    oauth_configuration: null
    api_key_env_var_name: null
    api_key_credential_provider_name: null
    is_generated_by_agentcore_create: false
